{
  "name": "@dev.smartpricing/traceflow-sdk",
  "version": "1.2.0",
  "description": "SDK for sending trace tracking messages to Kafka with automatic step management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "standard-version"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com-sp:smartpricing/traceflow-sdk.git"
  },
  "keywords": [
    "kafka",
    "tracing",
    "monitoring",
    "traces",
    "steps",
    "logs"
  ],
  "author": "Andrei Borcea",
  "license": "ISC",
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.6.0",
    "redis": "^5.9.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "standard-version": "^9.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
